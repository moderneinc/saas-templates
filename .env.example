# ──────────────────────────────────────────────────────────────────────────────
# Required
# ──────────────────────────────────────────────────────────────────────────────

# The URL of your Moderne tenant (no trailing slash)
MODERNE_TENANT_API_URL=https://api.<mycompany>.moderne.io

# A Moderne Personal Access Token with admin scope
# Create one at https://<TENANT>.moderne.io/settings/access-token
MODERNE_PAT=mod_pat_XXXXXXXXXXXX

# The S3 bucket (and optional key prefix) where CSV files will be uploaded.
# Files go to the bucket root by default. Include a path to add a prefix:
#   S3_BUCKET=my-bucket                        → s3://my-bucket/audit-events-*.csv
#   S3_BUCKET=my-bucket/path/to/audit-logs     → s3://my-bucket/path/to/audit-logs/audit-events-*.csv
S3_BUCKET=my-audit-logs-bucket

# ──────────────────────────────────────────────────────────────────────────────
# Optional – S3
# ──────────────────────────────────────────────────────────────────────────────

# AWS CLI named profile (from ~/.aws/credentials). Default: none (uses default chain)
# S3_PROFILE=my-profile

# AWS credentials – not needed if using an IAM role (recommended).
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# ──────────────────────────────────────────────────────────────────────────────
# Optional – sync behavior
# ──────────────────────────────────────────────────────────────────────────────

# How often the cron job runs (minutes). Default: 15
# SYNC_INTERVAL_MINUTES=15

# Seconds between download-status poll requests. Default: 5
# POLL_INTERVAL=5

# Maximum seconds to wait for the download to complete. Default: 120
# POLL_TIMEOUT=120
